# =============================================================
#  Calzados POS — Variables de entorno
#  Copia este archivo como .env y ajusta los valores
#
#    cp .env.example .env
#
#  El docker-compose.yml puede leer este archivo automáticamente
#  si está en la misma carpeta.
# =============================================================

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=calzados_pos
MYSQL_USER=calzados_user
MYSQL_PASSWORD=calzados_pass

# ── Backend ───────────────────────────────────────────────────
# JWT Secret — generar uno seguro con: openssl rand -hex 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# ── Puertos expuestos al host ──────────────────────────────────
FRONTEND_PORT=4200
BACKEND_PORT=8080
MYSQL_PORT=3306
